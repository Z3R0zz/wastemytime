[Unit]
Description=wastemytime
After=network-online.target

[Service]
Type=simple
ExecStart=%h/.local/bin/wastemytime --daemon
Restart=on-failure
RestartSec=30
EnvironmentFile=%h/.wastemytime_env
Environment=DISPLAY=:0
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=%t/bus

[Install]
WantedBy=default.target
