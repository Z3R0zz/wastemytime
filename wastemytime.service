[Unit]
Description=wastemytime
After=network-online.target

[Service]
Type=simple
WorkingDirectory=%h
ExecStart=%h/venv/bin/python main.py --daemon
Restart=on-failure
RestartSec=30
Environment=DISPLAY=:0
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus

[Install]
WantedBy=default.target
